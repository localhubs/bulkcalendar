# Auto detect text files and normalize line endings to LF
* text=auto

# JavaScript
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.mjs text eol=lf

# Markdown
*.md text eol=lf

# CSS
*.css text eol=lf
*.scss text eol=lf

# HTML
*.html text eol=lf
*.svg text eol=lf

# Shell
*.sh text eol=lf
*.bash text eol=lf

# Batch/CMD
*.bat text eol=crlf
*.cmd text eol=crlf

# Images
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary

# Archives
*.zip binary
*.tar binary
*.gz binary
